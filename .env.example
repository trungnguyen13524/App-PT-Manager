# --- NutriCoach - Environment Variables Template ---
# Copy file này thành file .env và điền các giá trị thực tế.

# URL của Backend API
EXPO_PUBLIC_API_URL=

# Key kết nối với AI Coach (Lấy từ Google AI Studio)
EXPO_PUBLIC_AI_API_KEY=your_gemini_key_here
EXPO_PUBLIC_AI_MODEL=gemini-2.0-flash-lite

# Cấu hình Database/Auth (Ví dụ: Supabase)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Flags điều khiển tính năng
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_DEBUG_MODE=true