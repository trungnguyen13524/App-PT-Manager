{
  "expo": {
    "name": "NutriCoach",
    "slug": "NutriCoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.nhanhwang.NutriCoach"
    },
    "web": {},
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép ứng dụng sử dụng camera để chụp ảnh bữa ăn hoặc mã vạch."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cho phép ứng dụng truy cập thư viện ảnh để bạn có thể cập nhật ảnh đại diện."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "a8750c04-9bda-4dc7-98ae-78cf1f603926"
      }
    }
  }
}
